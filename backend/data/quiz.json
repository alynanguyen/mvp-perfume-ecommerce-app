{

    "quiz_name": "Perfume Finder",
    "questions": [
      {
        "id": 1,
        "question": "What’s your gender preference?",
        "field": "gender",
        "type": "multiple",
        "required": true,
        "weight": 2,
        "options": ["Male", "Female", "Unisex"]
      },
      {
        "id": 2,
        "question": "What vibe or personality best describes you?",
        "field": "vibe",
        "type": "multiple",
        "required": true,
        "weight": 3,
        "options": ["Sexy", "Romantic", "Playful","Fresh", "Elegant", "Dark", "Comforting", "Bold", "Unusual", "Natural"]
      },
      {
        "id": 3,
        "question": "What’s the occasion?",
        "field": "occasion",
        "type": "multiple",
        "required": true,
        "weight": 3,
        "options": [
          "Office",
          "Casual",
          "School",
          "Daytime Event",
          "Travel",
          "Date Night",
          "Party",
          "Formal Dinner",
          "Theatre or Concert",
          "Evening Out",
          "Nightclub",
          "Outdoor Event",
          "Special Occasion",
          "Formal Gala",
          "After-hours Event",
          "Romantic Night",
          "Luxury Event"
        ]
      },
      {
        "id": 4,
        "question": "Which season or weather suits you best?",
        "field": "season",
        "type": "multiple",
        "required": true,
        "weight": 2,
        "options": ["Spring", "Summer", "Autumn", "Winter", "All-year"]
      },
      {
        "id": 5,
        "question": "How long do you want your perfume to last?",
        "field": "longevity_category",
        "type": "multiple",
        "required": true,
        "weight": 2,
        "options": [
          { "label": "Soft / Moderate", "value": [0, 6] },
          { "label": "Moderate / Strong", "value": [6, 10] },
          { "label": "Very Strong", "value": [10, 24] }
        ]
      },
      {
        "id": 6,
        "question": "Select the accords you love most.",
        "field": "accords",
        "type": "multiple",
        "required": true,
        "weight": 3,
        "options": [
          "Floral", "Fruity & Sweet", "Woody & Resinous", "Spicy & Warm", "Fresh & Clean", "Green & Earthy", "Aquatic & Marine", "Musky & Powdery", "Oriental & Exotic"
        ]
      },
      {
        "id": 7,
        "question": "Select the notes you love most.",
        "field": "liked_notes",
        "type": "multiple",
        "required": true,
        "weight": 3,
        "options": [
          "Citrus", "Floral", "Fruity", "Spicy", "Woody", "Resinous / Balsamic", "Gourmand / Sweet", "Aromatic / Herbal / Green", "Musky / Animalic", "Oriental / Warm", "Earthy / Smoky / Dry", "Marine / Fresh", "Unique"
        ]
      },
      {
        "id": 8,
        "question": "Do you have any notes that you hate?",
        "field": "disliked_notes",
        "type": "multiple",
        "optional": true,
        "weight": 3,
        "options": [
          "Citrus", "Floral", "Fruity", "Spicy", "Woody", "Resinous / Balsamic", "Gourmand / Sweet", "Aromatic / Herbal / Green", "Musky / Animalic", "Oriental / Warm", "Earthy / Smoky / Dry", "Marine / Fresh", "Unique"
        ]
      },
      {
        "id":9,
        "question": "Do you use any other odor products (e.g., scented body lotion, deodorant, etc.), if yes, how do they smell like?",
        "field": "secondary_accords",
        "type": "multiple",
        "optional": true,
        "weight": 1,
        "options": [
          "Floral", "Fruity & Sweet", "Woody & Resinous", "Spicy & Warm", "Fresh & Clean", "Green & Earthy", "Aquatic & Marine", "Musky & Powdery", "Oriental & Exotic"
        ]
      },
      {
        "id": 10,
        "question": "Choose your preferred price range (EUR).",
        "field": "price",
        "type": "multiple",
        "required": true,
        "weight": 2,
        "options": [
          { "label": "Budget", "range": [0, 100] },
          { "label": "Mid", "range": [100, 200] },
          { "label": "Luxury", "range": [200, 500] }
        ]
      }
    ],

